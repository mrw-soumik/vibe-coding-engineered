# MVPFlow AI Environment Configuration
# Copy this file to .env and update with your actual values

# Application Environment
# Options: development, testing, production
APP_ENV=development

# Application Settings
APP_NAME=MVPFlow AI
DEBUG=false

# Database Configuration
# Development: sqlite:///./mvpflow_dev.db
# Production: postgresql://user:password@localhost/mvpflow
DATABASE_URL=sqlite:///./mvpflow.db

# API Configuration
API_V1_STR=/api/v1

# Security
# WARNING: Generate a strong secret key for production using:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production-DO-NOT-USE-IN-PROD
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Enable JWT authentication
# Set to true for production
ENABLE_JWT_AUTH=false

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
# Enable rate limiting
RATE_LIMIT_ENABLED=true
# Number of requests allowed
RATE_LIMIT_REQUESTS=100
# Time window in seconds
RATE_LIMIT_WINDOW=60

# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE=logs/mvpflow.log

# Security Headers
# Enforce HTTPS
REQUIRE_HTTPS=false
# Use secure cookies
SECURE_COOKIES=false
# Cookie SameSite policy: strict, lax, none
SAME_SITE=lax

# Feature Flags
# Enable Swagger UI
ENABLE_SWAGGER_UI=true

# LLM (Claude) Integration
# When ANTHROPIC_API_KEY is set and USE_LLM=true, the workflow uses live Claude
# calls for requirements extraction, MVP scope, and evaluation. With no key (or
# USE_LLM=false) it falls back to the deterministic templates used for the demo.
# ANTHROPIC_API_KEY=sk-ant-...
USE_LLM=true
LLM_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=4096

# Alternative provider: Groq (used only if ANTHROPIC_API_KEY is NOT set).
# OpenAI-compatible; structured output via JSON mode. No adaptive thinking and
# no native web search (research falls back to knowledge-only). Free tier is
# rate-limited (429), the client retries with backoff. llama-3.1-8b-instant has
# the highest free limits; llama-3.3-70b-versatile / openai/gpt-oss-120b are
# higher quality but hit limits faster.
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Monitoring (optional), set to enable Sentry error tracking; no-op if unset.
# Requires the 'monitoring' extra: pip install ".[monitoring]".
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Jira Cloud Integration (optional)
# Used by `python -m app.cli ... --push-jira --jira-live` to create the generated
# tickets as real Jira issues. Leave unset to skip. NEVER commit a real token.
# Create a token at: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_BASE_URL=https://yoursite.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-atlassian-api-token
JIRA_PROJECT_KEY=WOR
# Story Points field id (optional). Auto-discovered by name if blank.
# JIRA_STORY_POINTS_FIELD=customfield_10016

# Production Database (example PostgreSQL)
# Uncomment and update for production
# DATABASE_URL=postgresql://user:password@localhost:5432/mvpflow
# SECRET_KEY=your-generated-secret-key-here
# APP_ENV=production
# DEBUG=false
# ENABLE_JWT_AUTH=true
# REQUIRE_HTTPS=true
# SECURE_COOKIES=true
# LOG_LEVEL=WARNING
